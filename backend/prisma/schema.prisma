  @@index([organizationId, campaignId, createdAt])
  @@index([organizationId, distributionListId, createdAt])
  @@index([organizationId, distributionMemberId, createdAt])
  @@index([organizationId, recipientPhoneE164])
  @@index([organizationId, status, createdAt])
